# Copy to `.env` (or `.env.local`) to customize. All values are optional.
# Vite only exposes variables prefixed with VITE_ to the client.

# Editable system name — shown in the boot splash, sidebar, and tab title.
VITE_SYSTEM_NAME="Ops Command Center"

# Optional shorter label for tight spaces (defaults to VITE_SYSTEM_NAME).
# VITE_SYSTEM_SHORT_NAME="OCC"
