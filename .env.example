# Copy to `.env` (or `.env.local`) to customize. All values are optional.
# Vite only exposes variables prefixed with VITE_ to the client.

# Editable system name — shown in the boot splash, sidebar, and tab title.
VITE_SYSTEM_NAME="Ops Command Center"

# Optional shorter label for tight spaces (defaults to VITE_SYSTEM_NAME).
# VITE_SYSTEM_SHORT_NAME="OCC"

# --- Backend mode ----------------------------------------------------------
# "mock" (default) uses in-browser mocks; "real" talks to the FastAPI BFF (backend/).
# VITE_API_MODE="real"
# VITE_API_BASE_URL="http://localhost:8000/api"

# --- Fleet Map -------------------------------------------------------------
# Tile source: "google" (default) | "osm" | "offline".
# VITE_MAP_TILE_SOURCE="google"
# For the air-gapped system, set the source to "offline" and point this at your
# internal tile server or a bundled tile pyramid:
# VITE_MAP_TILE_SOURCE="offline"
# VITE_MAP_TILE_URL="http://tiles.internal/{z}/{x}/{y}.png"
# Fallback view when the dataset is empty (map otherwise fits to the data):
# VITE_MAP_CENTER="32.0,34.9"
# VITE_MAP_ZOOM="7"
