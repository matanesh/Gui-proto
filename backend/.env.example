# Copy to backend/.env to override. All optional. No secrets belong in this repo.

# CORS origins allowed to call the BFF (comma-separated).
BFF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Broker mode. false = internal simulator drives runs (no RabbitMQ needed).
# true  = publish commands to RabbitMQ and consume Core events (needs the broker + core worker).
BFF_BROKER_ENABLED=false

# RabbitMQ connection (used only when BFF_BROKER_ENABLED=true). Placeholder creds.
BFF_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
BFF_COMMANDS_EXCHANGE=occ.commands
BFF_EVENTS_EXCHANGE=occ.events
BFF_EVENTS_QUEUE=occ.bff.events

# SSE
BFF_HEARTBEAT_INTERVAL_SEC=10
BFF_REPLAY_WINDOW=200
